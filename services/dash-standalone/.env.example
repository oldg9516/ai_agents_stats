# === REQUIRED ===

# Database to analyze (READ-ONLY access recommended)
# PostgreSQL:
#   DATA_DB_URL=postgresql+psycopg://user:password@host:5432/database
# MySQL:
#   DATA_DB_URL=mysql+pymysql://user:password@host:3306/database
DATA_DB_URL=mysql+pymysql://user:password@host:3306/database

# OpenAI API key (for GPT model + text-embedding-3-small)
OPENAI_API_KEY=sk-...

# === OPTIONAL ===

# PostgreSQL for agent state (knowledge, learnings, sessions)
# By default, a built-in pgvector container is used — no setup needed.
# Set this only if you want to use an external PostgreSQL with pgvector.
# AGENT_DB_URL=postgresql+psycopg://user:password@host:5432/database?options=-csearch_path%3Ddash,public

# Ports (defaults: agent=9000, frontend=3001)
# AGENT_PORT=9000
# FRONTEND_PORT=3001
