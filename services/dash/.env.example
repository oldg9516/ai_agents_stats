# === REQUIRED ===

# PostgreSQL — agent state, knowledge, learnings (schema: dash)
# Must have pgvector extension enabled: CREATE EXTENSION IF NOT EXISTS vector;
# Must have dash schema: CREATE SCHEMA IF NOT EXISTS dash;
AGENT_DB_URL=postgresql+psycopg://user:password@host:5432/dbname?options=-csearch_path%3Ddash,public

# PostgreSQL — read-only SQL queries (the database to analyze)
DATA_DB_URL=postgresql+psycopg://user:password@host:5432/dbname

# OpenAI API key (GPT model + text-embedding-3-small)
OPENAI_API_KEY=sk-...

# === OPTIONAL ===

# Port (default: 9000)
# PORT=9000

# Agent mode: "full" (with pre-loaded knowledge) or "generic" (auto-discover)
# AGENT_MODE=full

# Agent ID (used in AG-UI routing)
# AGENT_ID=dash

# PgVector table prefix (avoids collision between multiple instances)
# KNOWLEDGE_TABLE_PREFIX=dash
