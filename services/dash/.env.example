# === REQUIRED ===

# Supabase PostgreSQL — agent state, knowledge, learnings (schema: dash)
# pgvector extension must be enabled
AGENT_DB_URL=postgresql+psycopg://user:password@db.XXX.supabase.co:5432/postgres?options=-csearch_path%3Ddash,public

# Supabase PostgreSQL — read-only SQL queries (schema: public)
DATA_DB_URL=postgresql+psycopg://user:password@db.XXX.supabase.co:5432/postgres

# OpenAI API key (GPT model + text-embedding-3-small)
OPENAI_API_KEY=sk-...

# === OPTIONAL ===

# Port (default: 9000)
# PORT=9000

# Agent mode: "full" (with pre-loaded knowledge) or "generic" (auto-discover)
# AGENT_MODE=full

# Agent ID (used in AG-UI routing)
# AGENT_ID=dash

# PgVector table prefix (avoids collision between multiple instances)
# KNOWLEDGE_TABLE_PREFIX=dash
