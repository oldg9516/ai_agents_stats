# Supabase Configuration
# Get these values from your Supabase project settings:
# https://supabase.com/dashboard/project/_/settings/api

# Public keys (safe to expose on client)
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key (OPTIONAL - only if you have RLS enabled and need to bypass it)
# ⚠️ WARNING: Never expose this key on the client! Server-side only!
# If you don't have RLS enabled, you can omit this - anon key will be used instead
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Authentication Configuration
# Allowed email domain for Google OAuth (only users with this domain can sign in)
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=levhaolam.com

# Dash AI Agent (Python backend)
# URL where the Dash Docker service is running
DASH_BACKEND_URL=http://localhost:9000

# Supabase connection for Dash agent state/knowledge (schema: dash)
# DASH_AGENT_DB_URL=postgresql+psycopg://dash_agent:password@db.XXX.supabase.co:5432/postgres?sslmode=require&options=-csearch_path%3Ddash

# Supabase connection for read-only SQL queries (schema: public)
# DASH_DATA_DB_URL=postgresql+psycopg://dash_readonly:password@db.XXX.supabase.co:5432/postgres?sslmode=require

# OpenAI API key for Dash agent (GPT-5.1 + embeddings)
# OPENAI_API_KEY=sk-...

# Dash Test Agent (second instance, external database)
# DASH_TEST_BACKEND_URL=http://localhost:9001
# DASH_TEST_DATA_DB_URL=postgresql+psycopg://user:password@host:5432/database

# Instructions:
# 1. Copy this file to .env.local
# 2. Fill in your actual Supabase credentials
# 3. Never commit .env.local to git (it's already in .gitignore)
#
# Notes:
# - ANON_KEY: Used for client-side operations (has RLS restrictions)
# - SERVICE_ROLE_KEY: Bypasses RLS, use only on server (Server Actions, API Routes)
